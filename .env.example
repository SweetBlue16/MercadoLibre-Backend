# Mercado Libre Seguro - variables de entorno

NODE_ENV=development
SERVER_PORT=3000
PORT=3000
CORS_ORIGINS=http://localhost:8080

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=mercadolibre_user
DB_PASSWORD=change_this_local_password
DB_DATABASE=mercadolibre

# Seguridad
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRES_IN=20m
BCRYPT_SALT_ROUNDS=12

# Cuentas semilla
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace_with_strong_admin_password
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=replace_with_strong_user_password

# Archivos
FILES_IN_DB=false
UPLOADS_DIR=./uploads
MAX_IMAGE_SIZE_MB=5

# Correo / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mercadolibreps04@gmail.com
SMTP_PASSWORD=
SMTP_FROM="Mercado Libre PS04 <mercadolibreps04@gmail.com>"
EMAIL_CONFIRMATION_ENABLED=true
EMAIL_DEV_MODE=true
