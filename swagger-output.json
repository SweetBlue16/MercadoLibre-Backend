    "/api/productos/": {
      "get": {
        "tags": [
          "Productos"
        ],
        "summary": "Listar productos del catálogo",
        "description": "Obtiene la lista de productos y sus categorías vinculadas. Soporta búsqueda por coincidencia parcial en el título.",
        "parameters": [
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "type": "string"
          },
          {
            "name": "Authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "s",
            "in": "query",
            "description": "Termino de busqueda opcional",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Catálogo recuperado exitosamente."
