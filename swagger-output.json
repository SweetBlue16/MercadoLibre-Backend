        "tags": [
          "Productos"
        ],
        "summary": "Crear un nuevo producto",
        "description": "Los campos de texto son sanitizados contra XSS (CWE-79). El archivoid debe ser un entero positivo o nulo para mantener la integridad relacional.",
        "parameters": [
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "type": "string"
          },
          {
            "name": "Authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "titulo": {
                  "type": "string",
                  "example": "Teclado Mecánico"
                },
                "descripcion": {
                  "type": "string",
                  "example": "Teclado RGB switch rojo"
                },
                "precio": {
                  "type": "number",
                  "example": 1200.5
                },
                "archivoid": {
                  "type": "number",
                  "example": 1
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
