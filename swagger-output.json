    "/api/auth/": {
      "post": {
        "tags": [
          "Autenticación"
        ],
        "summary": "Iniciar sesión y obtener JWT",
        "description": "Genera un JWT seguro firmado con HS256. Las entradas están fuertemente validadas para evitar inyección SQL (CWE-89) y desbordamientos.",
        "parameters": [
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Credenciales de acceso",
            "schema": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "example": "admin@test.com"
                },
                "password": {
                  "type": "string",
                  "example": "password123"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Autenticación exitosa, retorna el JWT."
          },
          "400": {
            "description": "Datos mal formados detectados por express-validator."
          },
          "401": {
            "description": "Credenciales incorrectas (Manejo genérico para evitar filtración de usuarios existentes)."
          }
        }
      }
    },
