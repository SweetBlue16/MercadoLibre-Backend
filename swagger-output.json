            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "nombre": {
                  "type": "string",
                  "example": "Electrónica"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Categoría creada con éxito."
          }
        },
        "security": [
          {
            "bearerAuth": []
