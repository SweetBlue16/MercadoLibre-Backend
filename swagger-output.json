                "descripcion": {
                  "type": "string",
                  "example": "Teclado RGB switch rojo"
                },
                "precio": {
                  "type": "number",
                  "example": 1200.5
                },
                "archivoid": {
                  "type": "string",
                  "example": "123e4567-e89b-12d3-a456-426614174000"
