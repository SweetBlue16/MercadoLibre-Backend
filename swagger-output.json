        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "file",
            "in": "formData",
            "type": "file",
            "required": true,
            "description": "Archivo de imagen a subir (Max 5MB)."
          }
        ],
        "responses": {
          "201": {
            "description": "Archivo almacenado exitosamente."
          },
          "400": {
            "description": "Tipo de archivo no permitido o límite de tamaño excedido."
