{
  "swagger": "2.0",
  "info": {
    "title": "Mercado Libre Seguro - API Backend",
    "description": "Documentación oficial de la API de Mercado Libre Seguro. Incluye validaciones estrictas, auditoría y blindaje contra CWEs.",
    "version": "1.0.0",
    "contact": {
      "name": "Equipo de Desarrollo IOException Team",
      "url": "https://github.com/SweetBlue16/MercadoLibre-Backend"
    }
